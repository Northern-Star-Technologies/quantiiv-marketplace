{
  "description": "Check Quantiiv SDK and credentials on session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/check-setup.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
